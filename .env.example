# Django settings
DJANGO_SECRET_KEY=your-very-long-random-secret-key-here-change-this
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave DB_ENGINE as sqlite3 for local dev without Docker)
# For PostgreSQL (production / Docker):
DB_ENGINE=django.db.backends.postgresql
DB_NAME=taskmanager
DB_USER=taskmanager
DB_PASSWORD=taskmanager_password
DB_HOST=db
DB_PORT=5432

# Security (set to False only in local dev without HTTPS)
SECURE_SSL_REDIRECT=False 

